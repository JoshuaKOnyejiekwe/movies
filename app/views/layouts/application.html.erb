<!DOCTYPE html>
<html>
  <head>
    <title>Movie Watchlist</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>
  </head>

  <body>

    <nav class="navbar">

      <div class="nav-left">
        <a href="/" class="web-name">My Watchlist</a>
      <a href="/movies/new" class="movie-btn">Add Movie</a>
        <a href="/">Home</a>

        <a href="/movies">Movies</a>
      </div>

      <div class="nav-right">

        <a href="/movies/new" class="movie-btn">+ Add Movie 2</a>

        <% if user_signed_in? %>

          <span class="user-name">
            <%= current_user.email %>
          </span>

          <%= button_to "Log Out",
              destroy_user_session_path,
              method: :delete,
              class: "logout-btn" %>

        <% else %>

          <a href="/users/sign_in">
            Log In
          </a>

          <a href="/users/sign_up">
            Sign Up
          </a>

        <% end %>

      </div>
    </nav>

    <div class="container">
      <%= yield %>
    </div>

  </body>
</html>