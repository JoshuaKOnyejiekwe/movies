<!DOCTYPE html>
<html>
  <head>
    <title>Movie Watchlist</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

       <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class = "navbar">
      <a href="/" class="web-name">My Watchlist</a>
      <a href="/movies/new" class="movie-btn">Add Movie</a>
    </nav>

    <div class="container">
      <%= yield %>
    </div>

  
  </body>
</html>

<!-- This file is so that anything in it will display on everypage of the website / web app -->